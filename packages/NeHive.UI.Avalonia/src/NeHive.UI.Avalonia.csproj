<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>

        <LangVersion>latest</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <RootNamespace>NeHive.UI.Avalonia</RootNamespace>

        <!--        <GenerateDocumentationFile>true</GenerateDocumentationFile>-->
    </PropertyGroup>

    <PropertyGroup>
        <PackageId>NeHive.UI.Avalonia</PackageId>
        <Version>0.0.1-alpha</Version>

        <Authors>oanlit</Authors>

        <Description>UI integration layer for NeHive runtime model on Avalonia</Description>
        <PackageTags>ui;avalonia;runtime;ne-hive;reactive;dsl</PackageTags>

        <PackageIcon>logo.png</PackageIcon>
        <PackageReadmeFile>README.md</PackageReadmeFile>

        <PackageLicenseExpression>MIT</PackageLicenseExpression>
    </PropertyGroup>

    <PropertyGroup>
        <RepositoryUrl>https://github.com/oanlit/NeHive</RepositoryUrl>
        <RepositoryType>git</RepositoryType>

        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>

        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>

        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0">
            <PrivateAssets>all</PrivateAssets>
        </PackageReference>

        <PackageReference Include="Avalonia" Version="12.*"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\NeHive.Model\src\NeHive.Model.csproj"/>
        <ProjectReference Include="..\..\NeHive.Reactive\src\NeHive.Reactive.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="assets\logo.png"
              Pack="true"
              PackagePath="\"/>
        <None Include="README.md" Pack="true" PackagePath="README.md"/>
    </ItemGroup>
</Project>
